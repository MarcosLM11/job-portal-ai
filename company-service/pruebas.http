### Variables
@baseUrl = http://localhost:8080
@userId = 1
@companyId = 1

###
### 1. CREATE COMPANY - POST /api/companies
###
POST {{baseUrl}}/api/companies
Content-Type: application/json
X-User-Id: {{userId}}

{
  "name": "Tech Innovations Inc",
  "tagline": "Building the future with technology",
  "description": "A leading technology company specializing in AI and cloud solutions",
  "logoUrl": "https://example.com/logo.png",
  "coverImageUrl": "https://example.com/cover.png",
  "website": "https://techinnovations.com",
  "email": "info@techinnovations.com",
  "phone": "+1-555-0123",
  "foundedYear": 2015,
  "companySize": "LARGE",
  "companyType": "PRIVATE",
  "industryType": "TECHNOLOGY",
  "companyStatus": "PENDING_VERIFICATION",
  "registrationNumber": "REG-2015-001",
  "socialLinks": []
}

> {%
request.variables.set("companyId", response.body.id);
%}

