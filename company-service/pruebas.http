###
### 6. GET COMPANY BY ID - GET /api/companies/{companyId}
###
GET {{baseUrl}}/api/companies/{{companyId}}

###
### 7. GET COMPANY BY ID - Non-existent company
###
GET {{baseUrl}}/api/companies/99999

###
### 8. GET MY COMPANY - GET /api/companies/my
###
GET {{baseUrl}}/api/companies/my
X-User-Id: {{userId}}

###
### 9. GET MY COMPANY - Missing user header
###
GET {{baseUrl}}/api/companies/my

###
### 10. GET ALL COMPANIES - GET /api/companies
###
GET {{baseUrl}}/api/companies

###
### 11. GET ALL COMPANIES - Filter by company type
###
GET {{baseUrl}}/api/companies?companyType=STARTUP

###
### 12. GET ALL COMPANIES - Filter by industry type
###
GET {{baseUrl}}/api/companies?industryType=TECHNOLOGY

###
### 13. GET ALL COMPANIES - Filter by status
###
GET {{baseUrl}}/api/companies?companyStatus=ACTIVE

###
### 14. GET ALL COMPANIES - Multiple filters
###
GET {{baseUrl}}/api/companies?companyType=PRIVATE&industryType=FINANCE_BANKING&companyStatus=ACTIVE

###
### 15. UPDATE COMPANY - PUT /api/companies/{id}
###
PUT {{baseUrl}}/api/companies/{{companyId}}
Content-Type: application/json
X-User-Id: {{userId}}

{
  "name": "Tech Innovations Inc - Updated",
  "tagline": "Updated tagline for our company",
  "description": "Updated description with new details",
  "logoUrl": "https://example.com/logo-updated.png",
  "coverImageUrl": "https://example.com/cover-updated.png",
  "website": "https://techinnovations-updated.com",
  "email": "contact@techinnovations.com",
  "phone": "+1-555-0199",
  "foundedYear": 2015,
  "companySize": "ENTERPRISE",
  "companyType": "PRIVATE",
  "industryType": "TECHNOLOGY",
  "companyStatus": "ACTIVE",
  "registrationNumber": "REG-2015-001-UPD",
  "socialLinks": []
}

