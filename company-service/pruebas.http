Content-Type: application/json
X-User-Id: {{userId}}

{
  "name": "Another Company",
  "tagline": "Another tagline",
  "description": "Test description",
  "logoUrl": "https://example.com/logo.png",
  "coverImageUrl": "https://example.com/cover.png",
